# ── Server ──────────────────────────────────────────
PORT=3000

# ── Scraper Defaults ────────────────────────────────
DEFAULT_MARKETPLACE=com
REQUESTS_PER_MINUTE=20
JITTER_MAX_MS=2000
MAX_RETRIES=3
TIMEOUT_MS=15000

# ── Proxies (comma-separated host:port or user:pass@host:port) ──
# PROXIES=user:pass@proxy1.example.com:8080,user:pass@proxy2.example.com:8080
PROXIES=

# ── Logging ─────────────────────────────────────────
LOG_LEVEL=info
LOG_TO_FILE=true
